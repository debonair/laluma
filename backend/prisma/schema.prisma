generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                    @id @default(uuid())
  username               String                    @unique
  email                  String                    @unique
  passwordHash           String                    @map("password_hash")
  displayName            String?                   @map("display_name")
  aboutMe                String?                   @map("about_me")
  motherhoodStage        String?                   @map("motherhood_stage")
  profileImageUrl        String?                   @map("profile_image_url")
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")
  hasCompletedOnboarding Boolean                   @default(false) @map("has_completed_onboarding")
  keycloakId             String?                   @unique @map("keycloak_id")
  isActive               Boolean                   @default(true) @map("is_active")
  isVerified             Boolean                   @default(false) @map("is_verified")
  journeyContext         String?                   @map("journey_context")
  lifeStage              String?                   @map("life_stage")
  verificationMethod     String?                   @map("verification_method")
  role                   UserRole                  @default(member) @map("role")
  commentLikes           CommentLike[]
  comments               Comment[]
  communityGuidelines    CommunityGuidelines[]     @relation("CommunityGuidelinesCreator")
  connectionsReceived    Connection[]              @relation("ConnectionRecipient")
  connectionsSent        Connection[]              @relation("ConnectionRequester")
  contentAuthored        Content[]                 @relation("ContentAuthor")
  contentBookmarks       ContentBookmark[]         @relation("ContentBookmarks")
  contentComments        ContentComment[]          @relation("ContentCommentAuthor")
  contentLikes           ContentLike[]             @relation("ContentLikes")
  contentSubmissions     ContentSubmission[]       @relation("UserContentSubmissions")
  conversations          ConversationParticipant[]
  directoryReviews       DirectoryReview[]
  eventRegistrations     EventRegistration[]
  eventWaitlists         EventWaitlist[]
  organizedEvents        Event[]                   @relation("EventOrganizer")
  groupMemberships       GroupMember[]
  createdGroups          Group[]                   @relation("GroupCreator")
  marketplaceItems       MarketplaceItem[]
  messagesSent           Message[]                 @relation("MessageSender")
  moderationAudit        ModerationAuditLog[]      @relation("ModerationAuditModerator")
  notificationsTriggered Notification[]            @relation("NotificationActor")
  notifications          Notification[]            @relation("UserNotifications")
  pollVotes              PollVote[]
  postLikes              PostLike[]
  posts                  Post[]
  pushDeviceTokens       PushDeviceToken[]
  reports                Report[]
  subscription           Subscription?
  blockedBy              UserBlock[]               @relation("BlockedBy")
  blockedUsers           UserBlock[]               @relation("BlockedUsers")
  messageReactions       MessageReaction[]         @relation("UserMessageReactions")
  preferences            UserPreference?
  brandProfile           BrandProfile?             @relation("UserBrandProfile")
  surveyResponses        SurveyResponse[]
  surveyTracking         UserSurveyTracking[]

  @@index([username])
  @@index([email])
  @@map("users")
}

model UserPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  lookingFor         String[] @map("looking_for")
  locationRadius     Int      @default(10) @map("location_radius")
  locationAnywhere   Boolean  @default(false) @map("location_anywhere")
  latitude           Float?
  longitude          Float?
  city               String?
  country            String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  interestedInEvents Boolean  @default(true) @map("interested_in_events")
  interestedInPromos Boolean  @default(true) @map("interested_in_promos")
  notifyDms          Boolean  @default(true) @map("notify_dms")
  notifyEvents       Boolean  @default(true) @map("notify_events")
  notifyGroups       Boolean  @default(true) @map("notify_groups")
  notifyModeration   Boolean  @default(true) @map("notify_moderation")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Group {
  id                 String        @id @default(uuid())
  name               String        @unique
  description        String
  imageEmoji         String?       @map("image_emoji")
  imageUrl           String?       @map("image_url")
  createdById        String?       @map("created_by_id")
  memberCount        Int           @default(0) @map("member_count")
  isPrivate          Boolean       @default(false) @map("is_private")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  city               String?
  country            String?
  latitude           Float?
  longitude          Float?
  moderationSettings Json?         @map("moderation_settings")
  members            GroupMember[]
  createdBy          User?         @relation("GroupCreator", fields: [createdById], references: [id])
  posts              Post[]

  @@index([name])
  @@index([latitude, longitude])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Post {
  id             String          @id @default(uuid())
  groupId        String          @map("group_id")
  authorId       String?         @map("author_id")
  content        String
  likesCount     Int             @default(0) @map("likes_count")
  commentsCount  Int             @default(0) @map("comments_count")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  identityLinkId String?         @map("identity_link_id")
  isAnonymous    Boolean         @default(false) @map("is_anonymous")
  mediaUrls      String[]        @map("media_urls")
  comments       Comment[]
  moderationItem ModerationItem?
  poll           Poll?
  likes          PostLike[]
  author         User?           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group          Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id             String          @id @default(uuid())
  postId         String          @map("post_id")
  authorId       String?         @map("author_id")
  content        String
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  isAnonymous    Boolean         @default(false) @map("is_anonymous")
  likesCount     Int             @default(0) @map("likes_count")
  mediaUrls      String[]        @map("media_urls")
  parentId       String?         @map("parent_id")
  likes          CommentLike[]
  author         User?           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent         Comment?        @relation("ParentComments", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        Comment[]       @relation("ParentComments")
  post           Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  moderationItem ModerationItem?

  @@index([postId])
  @@map("comments")
}

model PostLike {
  id           String   @id @default(uuid())
  postId       String   @map("post_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  reactionType String   @default("like") @map("reaction_type")
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_likes")
}

model CommentLike {
  id           String   @id @default(uuid())
  commentId    String   @map("comment_id")
  userId       String   @map("user_id")
  reactionType String   @default("like") @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at")
  comment      Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

model MarketplaceItem {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  title       String
  description String
  price       Float    @default(0)
  condition   String
  category    String
  latitude    Float
  longitude   Float
  status      String   @default("available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@map("marketplace_items")
}

model DirectoryListing {
  id          String            @id @default(uuid())
  name        String
  category    String
  address     String?
  latitude    Float
  longitude   Float
  description String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  reviews     DirectoryReview[]

  @@index([latitude, longitude])
  @@map("directory_listings")
}

model DirectoryReview {
  id        String           @id @default(uuid())
  listingId String           @map("listing_id")
  authorId  String           @map("author_id")
  rating    Int
  content   String
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  listing   DirectoryListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("directory_reviews")
}

model Content {
  id             String            @id @default(uuid())
  title          String
  body           String
  excerpt        String?
  category       String
  authorName     String?           @map("author_name")
  authorId       String?           @map("author_id")
  thumbnailUrl   String?           @map("thumbnail_url")
  videoUrl       String?           @map("video_url")
  videoDuration  Int?              @map("video_duration")
  videoThumbnail String?           @map("video_thumbnail")
  contentType    String            @default("article") @map("content_type")
  sponsorName    String?           @map("sponsor_name")
  sponsorLogoUrl String?           @map("sponsor_logo_url")
  sponsorLink    String?           @map("sponsor_link")
  isPremium      Boolean           @default(false) @map("is_premium")
  premiumTier    String?           @map("premium_tier")
  isFeatured     Boolean           @default(false) @map("is_featured")
  isActive       Boolean           @default(true) @map("is_active")
  status         String            @default("draft")
  viewCount      Int               @default(0) @map("view_count")
  likesCount     Int               @default(0) @map("likes_count")
  commentsCount  Int               @default(0) @map("comments_count")
  bookmarksCount Int               @default(0) @map("bookmarks_count")
  publishedAt    DateTime?         @map("published_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  discountCode   String?           @map("discount_code")
  discountValue  String?           @map("discount_value")
  eventDate      DateTime?         @map("event_date")
  eventLocation  String?           @map("event_location")
  latitude       Float?
  longitude      Float?
  author         User?             @relation("ContentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  bookmarks      ContentBookmark[]
  comments       ContentComment[]
  likes          ContentLike[]
  moderationItem ModerationItem?
  poll           Poll?

  @@index([category])
  @@index([isPremium])
  @@index([status])
  @@index([publishedAt])
  @@index([isFeatured])
  @@map("content")
}

model ContentComment {
  id          String   @id @default(uuid())
  contentId   String   @map("content_id")
  authorId    String?  @map("author_id")
  commentText String   @map("comment_text")
  status      String   @default("visible")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  author      User?    @relation("ContentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@map("content_comments")
}

model ContentLike {
  id        String   @id @default(uuid())
  contentId String   @map("content_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation("ContentLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([userId])
  @@map("content_likes")
}

model AnonymousPostLink {
  id              String   @id @default(uuid())
  identityLinkId  String   @unique @map("identity_link_id")
  encryptedUserId String   @map("encrypted_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([identityLinkId])
  @@map("anonymous_post_links")
}

model ContentBookmark {
  id        String   @id @default(uuid())
  contentId String   @map("content_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation("ContentBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([userId])
  @@map("content_bookmarks")
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  tier                 String    @default("free")
  status               String    @default("active")
  platform             String?
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([status])
  @@map("subscriptions")
}

model ContentSubmission {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  title             String
  body              String
  category          String
  status            String   @default("pending")
  rejectionReason   String?  @map("rejection_reason")
  approvedContentId String?  @map("approved_content_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation("UserContentSubmissions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("content_submissions")
}

model BrandContent {
  id             String             @id @default(uuid())
  partnerId      String             @map("partner_id")
  title          String
  content        String
  imageUrl       String?            @map("image_url")
  discountCode   String?            @map("discount_code")
  status         BrandContentStatus @default(DRAFT)
  editorialNotes String?            @map("editorial_notes")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  partner        BrandProfile       @relation("BrandProfileContent", fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("brand_content")
}

enum BrandContentStatus {
  DRAFT
  PENDING
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  actorId   String?  @map("actor_id")
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  actor     User?    @relation("NotificationActor", fields: [actorId], references: [id])
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  joinedAt       DateTime     @default(now()) @map("joined_at")
  lastReadAt     DateTime?    @map("last_read_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(uuid())
  content        String
  createdAt      DateTime     @default(now()) @map("created_at")
  isRead         Boolean      @default(false) @map("is_read")
  senderId       String       @map("sender_id")
  conversationId String       @map("conversation_id")
  attachmentType String?      @map("attachment_type")
  attachmentUrl  String?      @map("attachment_url")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  reactions      MessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model MessageReaction {
  id           String   @id @default(uuid())
  messageId    String   @map("message_id")
  userId       String   @map("user_id")
  reactionType String   @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at")
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user         User     @relation("UserMessageReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_reactions")
}

model Connection {
  id          String   @id @default(uuid())
  requesterId String   @map("requester_id")
  recipientId String   @map("recipient_id")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  recipient   User     @relation("ConnectionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  requester   User     @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([requesterId])
  @@index([recipientId])
  @@map("connections")
}

model PushDeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_device_tokens")
}

model Poll {
  id        String       @id @default(uuid())
  postId    String?      @unique @map("post_id")
  contentId String?      @unique @map("content_id")
  question  String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  expiresAt DateTime?    @map("expires_at")
  options   PollOption[]
  votes     PollVote[]
  content   Content?     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("polls")
}

model PollOption {
  id     String     @id @default(uuid())
  pollId String     @map("poll_id")
  text   String
  order  Int        @default(0)
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String     @map("poll_id")
  optionId  String     @map("option_id")
  userId    String     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
  @@map("poll_votes")
}

model SystemStatus {
  id        String   @id @default(uuid())
  message   String
  type      String   @default("info")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_status")
}

model ModerationItem {
  id          String               @id @default(uuid())
  status      String               @default("pending")
  isEscalated Boolean              @default(false) @map("is_escalated")
  postId      String?              @unique @map("post_id")
  commentId   String?              @unique @map("comment_id")
  contentId   String?              @unique @map("content_id")
  aiScore     Float?               @map("ai_score")
  aiCategory  String?              @map("ai_category")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  auditLogs   ModerationAuditLog[]
  comment     Comment?             @relation(fields: [commentId], references: [id], onDelete: Cascade)
  content     Content?             @relation(fields: [contentId], references: [id], onDelete: Cascade)
  post        Post?                @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports     Report[]

  @@map("moderation_items")
}

model Report {
  id               String         @id @default(uuid())
  moderationItemId String         @map("moderation_item_id")
  reporterId       String         @map("reporter_id")
  reason           String
  createdAt        DateTime       @default(now()) @map("created_at")
  moderationItem   ModerationItem @relation(fields: [moderationItemId], references: [id], onDelete: Cascade)
  reporter         User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([moderationItemId, reporterId])
  @@index([reporterId])
  @@map("reports")
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")
  blocked   User     @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlockedUsers", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

model ModerationAuditLog {
  id               String         @id @default(uuid())
  moderationItemId String         @map("moderation_item_id")
  moderatorId      String         @map("moderator_id")
  action           String
  reason           String?
  metadata         Json?
  createdAt        DateTime       @default(now()) @map("created_at")
  moderationItem   ModerationItem @relation(fields: [moderationItemId], references: [id], onDelete: Cascade)
  moderator        User           @relation("ModerationAuditModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([moderationItemId])
  @@index([moderatorId])
  @@index([createdAt])
  @@map("moderation_audit_logs")
}

model CommunityGuidelines {
  id          String   @id @default(uuid())
  content     String
  version     Int      @default(1)
  publishedAt DateTime @map("published_at")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  creator     User     @relation("CommunityGuidelinesCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([publishedAt])
  @@index([createdBy])
  @@map("community_guidelines")
}

model Event {
  id                   String              @id @default(uuid())
  title                String
  description          String
  location             String?
  address              String?
  latitude             Float?
  longitude            Float?
  city                 String?
  country              String?
  capacity             Int                 @default(0)
  registeredCount      Int                 @default(0) @map("registered_count")
  status               EventStatus         @default(draft)
  startTime            DateTime            @map("start_time")
  endTime              DateTime            @map("end_time")
  registrationDeadline DateTime?           @map("registration_deadline")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  organizerId          String?             @map("organizer_id")
  registrations        EventRegistration[]
  waitlists            EventWaitlist[]
  organizer            User?               @relation("EventOrganizer", fields: [organizerId], references: [id])

  @@index([title])
  @@index([status])
  @@index([startTime])
  @@index([latitude, longitude])
  @@index([city])
  @@index([organizerId])
  @@map("events")
}

model EventRegistration {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  eventId      String             @map("event_id")
  status       RegistrationStatus @default(confirmed)
  registeredAt DateTime           @default(now()) @map("registered_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("event_registrations")
}

model EventWaitlist {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  eventId    String    @map("event_id")
  position   Int
  notifiedAt DateTime? @map("notified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, position])
  @@map("event_waitlists")
}

model BrandInquiry {
  id              String   @id @default(uuid())
  companyName     String   @map("company_name")
  contactName     String   @map("contact_name")
  email           String
  intent          String
  valuesAlignment String   @map("values_alignment")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("brand_inquiries")
}

enum UserRole {
  member
  moderator
  editorial
  admin
  brand_partner

  @@map("user_role")
}

enum EventStatus {
  draft
  published
  cancelled
  completed

  @@map("event_status")
}

enum RegistrationStatus {
  confirmed
  waitlisted
  cancelled

  @@map("registration_status")
}

model BrandProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  companyName     String   @map("company_name")
  logoUrl         String?  @map("logo_url")
  website         String?
  bio             String?
  category        String?
  instagramHandle String?  @map("instagram_handle")
  facebookUrl     String?  @map("facebook_url")
  isVerified      Boolean  @default(false) @map("is_verified")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  brandContent    BrandContent[] @relation("BrandProfileContent")
  user            User           @relation("UserBrandProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

model Survey {
  id          String         @id @default(uuid())
  slug        String         @unique
  title       String
  description String?
  questions   Json           // Array of question objects: { id, type, label, options?, required }
  isActive    Boolean        @default(true) @map("is_active")
  triggerDays Int            @default(7) @map("trigger_days")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  responses   SurveyResponse[]
  userTracking UserSurveyTracking[]

  @@map("surveys")
}

model SurveyResponse {
  id        String   @id @default(uuid())
  surveyId  String   @map("survey_id")
  userId    String   @map("user_id")
  responses Json     // Dictionary of { questionId: answer }
  createdAt DateTime @default(now()) @map("created_at")
  survey    Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("survey_responses")
}

model UserSurveyTracking {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  surveyId    String    @map("survey_id")
  status      String    @default("sent") // sent, completed, dismissed
  sentAt      DateTime  @default(now()) @map("sent_at")
  completedAt DateTime? @map("completed_at")
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, surveyId])
  @@map("user_survey_tracking")
}
